{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "integer" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "integer" },
        "featured": { "type": "boolean" },
        "trending": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Counter": {
      "title": "Counter",
      "description": "Sequential counter for IDs.",
      "type": "object",
      "properties": {
        "value": { "type": "integer" }
      },
      "required": ["value"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "subtotal": { "type": "number" },
        "deliveryCharge": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["bkash", "nagad", "rocket", "card", "cod"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "deliveryArea": { "type": "string", "enum": ["inside-dhaka", "outside-dhaka"] },
        "transactionId": { "type": "string" },
        "paymentScreenshot": { "type": "string" },
        "customerNote": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerName", "phone", "address", "items", "total", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon details.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minOrder": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["code", "discountType", "value"]
    },
    "Config": {
      "title": "Config",
      "description": "App configuration (delivery charges, etc.).",
      "type": "object",
      "properties": {
        "deliveryInsideDhaka": { "type": "number" },
        "deliveryOutsideDhaka": { "type": "number" }
      }
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global store settings including banners and logo.",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" },
        "facebook": { "type": "string" },
        "instagram": { "type": "string" },
        "youtube": { "type": "string" },
        "twitter": { "type": "string" },
        "deliveryChargeInside": { "type": "number" },
        "deliveryChargeOutside": { "type": "number" },
        "topBannerText": { "type": "string" },
        "topBannerLink": { "type": "string" },
        "bannerTextColor": { "type": "string" },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "image": { "type": "string" }
            },
            "required": ["name"]
          }
        },
        "banners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "subtitle": { "type": "string" },
              "image": { "type": "string" },
              "link": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews."
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupons."
    },
    "/config/settings": {
      "schema": "Config",
      "description": "Global app settings."
    },
    "/settings/site": {
      "schema": "SiteSettings",
      "description": "Store contact and delivery info."
    },
    "/counters/{counterId}": {
      "schema": "Counter",
      "description": "Sequential counters for IDs."
    }
  }
}
